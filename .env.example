# Supabase - get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend - get your API key from resend.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@crownportlogistics.site
RESEND_FROM_NAME=Crownport Logistics

# Admin notifications
ADMIN_ALERT_EMAIL=admin@crownportlogistics.site

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://crownportlogistics.site

# Company branding (also editable in admin settings panel)
NEXT_PUBLIC_COMPANY_NAME=Crownport Logistics
